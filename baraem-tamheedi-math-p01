<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>رياضيات التمهيدي - صفحة 01</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Tajawal', Arial, sans-serif; direction: rtl; }
    .hero-gradient { background: linear-gradient(135deg, #1a365d 0%, #2d3748 100%); }
    .card-hover { transition: all 0.3s ease; }
    .card-hover:hover { transform: translateY(-4px); box-shadow: 0 20px 25px -5px rgba(0,0,0,.12), 0 10px 10px -5px rgba(0,0,0,.06); }
    .btn-hover { transition: all 0.25s ease; }
    .btn-hover:hover { transform: scale(1.04); }
    .option-btn { transition: all 0.2s ease; }
    .option-btn:hover { transform: scale(1.02); }
  </style>
</head>
<body class="min-h-screen bg-gray-50 text-right">

  <header class="sticky top-0 z-40 bg-white shadow-md">
    <div class="max-w-6xl mx-auto px-4 py-4 flex flex-col md:flex-row items-center justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold text-blue-900">روضة البراعم</h1>
        <p class="text-sm text-gray-600">رياضيات التمهيدي - الصفحة 01</p>
      </div>

      <div class="flex gap-3">
        <a href="baraem-exercises.html" class="bg-gray-200 text-gray-800 px-5 py-2 rounded-full font-medium hover:bg-gray-300 btn-hover">
          العودة لاختيار التمارين
        </a>
        <a href="rawdah-baraem.html" class="bg-blue-900 text-white px-5 py-2 rounded-full font-medium hover:bg-blue-800 btn-hover">
          صفحة الروضة
        </a>
      </div>
    </div>
  </header>

  <section class="hero-gradient text-white py-14 md:py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-4xl md:text-5xl font-bold mb-5">الصفحة التفاعلية الأولى</h2>
      <p class="text-lg md:text-xl opacity-90 leading-9">
        هذه الصفحة تمثل نسخة رقمية لصفحة من الكتاب المطبوع، ويمكن عبرها حل التمارين وحفظ النتيجة لتظهر في صفحة المعلمة الخاصة بروضة البراعم.
      </p>
    </div>
  </section>

  <section class="py-12">
    <div class="max-w-4xl mx-auto px-4">
      <div class="bg-white rounded-2xl shadow-lg p-8 border border-gray-100">
        <h3 class="text-2xl font-bold text-blue-900 mb-6 text-center">بيانات الطالب</h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div>
            <label class="block mb-2 font-medium text-gray-700">اسم الطالب</label>
            <input id="studentName" type="text" placeholder="اكتب اسم الطالب"
              class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-blue-900 focus:outline-none">
          </div>

          <div>
            <label class="block mb-2 font-medium text-gray-700">الشعبة / الصف</label>
            <input id="className" type="text" placeholder="مثال: التمهيدي A"
              class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-blue-900 focus:outline-none">
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-16">
    <div class="max-w-4xl mx-auto px-4 space-y-6">

      <div class="card-hover bg-white rounded-2xl shadow-sm p-6 border border-gray-100">
        <h4 class="text-xl font-bold text-blue-900 mb-4">التمرين 1: اختر الرقم الصحيح</h4>
        <p class="text-gray-700 mb-4">كم عدد التفاحات في الصورة التخيلية؟ (الإجابة الصحيحة: 3)</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <button class="option-btn q1 bg-gray-100 py-3 rounded-xl border border-gray-200" data-value="2">2</button>
          <button class="option-btn q1 bg-gray-100 py-3 rounded-xl border border-gray-200" data-value="3">3</button>
          <button class="option-btn q1 bg-gray-100 py-3 rounded-xl border border-gray-200" data-value="4">4</button>
        </div>
      </div>

      <div class="card-hover bg-white rounded-2xl shadow-sm p-6 border border-gray-100">
        <h4 class="text-xl font-bold text-blue-900 mb-4">التمرين 2: اختر الشكل المناسب</h4>
        <p class="text-gray-700 mb-4">أي شكل يمثل دائرة؟</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <button class="option-btn q2 bg-gray-100 py-3 rounded-xl border border-gray-200" data-value="square">مربع</button>
          <button class="option-btn q2 bg-gray-100 py-3 rounded-xl border border-gray-200" data-value="circle">دائرة</button>
          <button class="option-btn q2 bg-gray-100 py-3 rounded-xl border border-gray-200" data-value="triangle">مثلث</button>
        </div>
      </div>

      <div class="card-hover bg-white rounded-2xl shadow-sm p-6 border border-gray-100">
        <h4 class="text-xl font-bold text-blue-900 mb-4">التمرين 3: اختر الإجابة الصحيحة</h4>
        <p class="text-gray-700 mb-4">1 + 1 = ؟</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <button class="option-btn q3 bg-gray-100 py-3 rounded-xl border border-gray-200" data-value="1">1</button>
          <button class="option-btn q3 bg-gray-100 py-3 rounded-xl border border-gray-200" data-value="2">2</button>
          <button class="option-btn q3 bg-gray-100 py-3 rounded-xl border border-gray-200" data-value="3">3</button>
        </div>
      </div>

      <div class="text-center pt-4">
        <button id="submitBtn" class="bg-blue-900 text-white px-10 py-3 rounded-full font-medium hover:bg-blue-800 btn-hover">
          إنهاء وحفظ النتيجة
        </button>
        <p id="resultMessage" class="mt-5 text-lg font-bold text-gray-700"></p>
      </div>
    </div>
  </section>

  <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore-compat.js"></script>

  <script>
    const firebaseConfig = {
      apiKey: "AIzaSyCvMD5nCvSVsKtSMVfELNFLHXSv3LSi0",
      authDomain: "interactive-book-37270.firebaseapp.com",
      projectId: "interactive-book-37270",
      storageBucket: "interactive-book-37270.appspot.com",
      messagingSenderId: "350364566140",
      appId: "1:350364566140:web:7997fb848a9b512f6b7ff9",
      measurementId: "G-QM0TNEN9XJ"
    };

    if (!firebase.apps.length) {
      firebase.initializeApp(firebaseConfig);
    }

    const db = firebase.firestore();

    const answers = { q1: null, q2: null, q3: null };

    function activateChoice(groupClass, selectedButton) {
      document.querySelectorAll("." + groupClass).forEach(btn => {
        btn.classList.remove("bg-blue-900", "text-white", "border-blue-900");
        btn.classList.add("bg-gray-100", "border-gray-200");
      });

      selectedButton.classList.remove("bg-gray-100", "border-gray-200");
      selectedButton.classList.add("bg-blue-900", "text-white", "border-blue-900");
    }

    document.querySelectorAll(".q1").forEach(btn => {
      btn.addEventListener("click", function() {
        answers.q1 = this.dataset.value;
        activateChoice("q1", this);
      });
    });

    document.querySelectorAll(".q2").forEach(btn => {
      btn.addEventListener("click", function() {
        answers.q2 = this.dataset.value;
        activateChoice("q2", this);
      });
    });

    document.querySelectorAll(".q3").forEach(btn => {
      btn.addEventListener("click", function() {
        answers.q3 = this.dataset.value;
        activateChoice("q3", this);
      });
    });

    document.getElementById("submitBtn").addEventListener("click", function() {
      const studentName = document.getElementById("studentName").value.trim();
      const className = document.getElementById("className").value.trim();
      const resultMessage = document.getElementById("resultMessage");

      if (!studentName) {
        resultMessage.innerText = "يرجى كتابة اسم الطالب أولًا";
        resultMessage.className = "mt-5 text-lg font-bold text-red-600";
        return;
      }

      if (!answers.q1 || !answers.q2 || !answers.q3) {
        resultMessage.innerText = "يرجى حل جميع التمارين أولًا";
        resultMessage.className = "mt-5 text-lg font-bold text-red-600";
        return;
      }

      let score = 0;
      if (answers.q1 === "3") score++;
      if (answers.q2 === "circle") score++;
      if (answers.q3 === "2") score++;

      const total = 3;

      db.collection("results").add({
        studentName: studentName,
        className: className || "",
        score: score,
        total: total,
        exercise: "math-page-01",
        kindergarten: "baraem",
        kindergartenName: "روضة البراعم",
        stage: "tamheedi",
        subject: "math",
        pageNumber: 1,
        teacherPage: "results-baraem.html",
        createdAt: new Date().toISOString()
      })
      .then(function() {
        resultMessage.innerText = `تم حفظ النتيجة بنجاح: ${score} / ${total}`;
        resultMessage.className = "mt-5 text-lg font-bold text-green-600";
      })
      .catch(function(error) {
        console.error(error);
        resultMessage.innerText = "حدث خطأ أثناء حفظ النتيجة";
        resultMessage.className = "mt-5 text-lg font-bold text-red-600";
      });
    });
  </script>

</body>
</html>
